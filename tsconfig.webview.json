{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "out/webview-typecheck",
    "rootDir": "src",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": []
  },
  "include": ["src/webview/**/*", "src/webview-protocol.ts", "src/rsvpEngine.ts"]
}
